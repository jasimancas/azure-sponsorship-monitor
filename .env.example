# .env.example — copia esto a .env y rellena tus valores
# El .env NUNCA se sube a Git (está en .gitignore)

# ── Autenticación Azure (Service Principal) ──────────────────────
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=tu-secret-aqui

# ── Offer IDs a monitorizar (separados por coma) ──────────────────
# MS-AZR-0036P = Azure Sponsorship / Partner Benefits
AZURE_OFFER_IDS=MS-AZR-0036P

# ── RateCard ─────────────────────────────────────────────────────
AZURE_CURRENCY=EUR
AZURE_LOCALE=es-ES
AZURE_REGION_INFO=ES

# ── App ──────────────────────────────────────────────────────────
FLASK_SECRET_KEY=cambia-esto-por-algo-aleatorio-en-produccion
MAX_WORKERS=8
REFRESH_HOURS=3
